# Copy this to .env and fill in real values.
# Never commit .env to source control.

# ── Gateway Auth ─────────────────────────────────────────────────────────────
# Comma-separated API keys for development.
# In production, use keys.json with hashed keys instead.
GATEWAY_API_KEYS=sk-dev-changeme

# ── Upstream LLM ─────────────────────────────────────────────────────────────
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-openai-your-key-here
